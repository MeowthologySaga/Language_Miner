{
  "manifest_version": 3,
  "default_locale": "en",
  "key": "",
  "name": "__MSG_extensionName__",
  "short_name": "__MSG_extensionShortName__",
  "version": "0.2.0",
  "description": "__MSG_extensionDescription__",
  "permissions": ["storage", "alarms", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:17345/*",
    "https://discord.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": [
        "src/shared/i18n.js",
        "src/shared/maskSensitiveText.js",
        "src/shared/filterLifeLogText.js",
        "src/content/adapters/discord.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "src/shared/i18n.js",
        "src/shared/maskSensitiveText.js",
        "src/shared/filterLifeLogText.js",
        "src/content/adapters/chatgpt.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "src/shared/i18n.js",
        "src/shared/maskSensitiveText.js",
        "src/shared/filterLifeLogText.js",
        "src/content/adapters/claude.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": ["http://127.0.0.1/*", "http://localhost/*"],
      "js": [
        "src/shared/i18n.js",
        "src/shared/geminiPricing.js",
        "src/content/selectionCards.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": [
        "src/shared/i18n.js",
        "src/content/youtubeDualSubtitles.js",
        "src/content/youtubeWatchCollector.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
